<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Tell the system this app requires OpenGL ES 2.0. -->
    <uses-feature android:glEsVersion="0x00020000" android:required="true" />

    <application

            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:name="io.github.nvlad1.function3danimator.AnimatorApplication"
            android:supportsRtl="true"
            android:allowBackup="true"
            android:theme="@style/AppTheme.NoActionBar">

        <activity
            android:name="io.github.nvlad1.function3danimator.ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="io.github.nvlad1.function3danimator.ui.functions_list.FunctionListActivity"
            android:exported="false"
            android:label="@string/functions_list"
            android:theme="@style/AppTheme">
        </activity>
        <activity
            android:name="io.github.nvlad1.function3danimator.ui.function_screen.FunctionActivityCompose"
            android:exported="false"
            android:label="@string/edit_function"
            android:theme="@style/AppTheme">
        </activity>
        <activity
            android:name="io.github.nvlad1.function3danimator.ui.settings.SettingsActivity"
            android:exported="false"
            android:label="@string/settings"
            android:theme="@style/AppTheme">
        </activity>
        <activity
            android:name="io.github.nvlad1.function3danimator.ui.help.HelpActivity"
            android:exported="false"
            android:label="@string/help"
            android:theme="@style/AppTheme">
        </activity>
    </application>

</manifest>